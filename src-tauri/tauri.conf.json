{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Planner",
  "version": "0.1.0",
  "identifier": "com.appnew.focusplanner",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Focus Planner",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
